# Environment / secret files — never commit these
.env
.env.local
.env.*.local

# Backend secrets (also covered by backend/.gitignore)
backend/src/main/resources/application-local.properties

# Backend build output
backend/target/

# Frontend build output & dependencies
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/

# Uploaded files (too large for git)
backend/uploads/
backend/src/main/resources/static/uploads/

# OS / editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.sw?
